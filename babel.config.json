{
  "presets": [
    ["@babel/preset-env", { "targets": { "node": "current" } }],
    [
      "@babel/preset-react",
      {
        "runtime": "automatic"
      }
    ],
    "@babel/preset-typescript"
  ],
  "plugins": [
    "@babel/plugin-transform-class-properties",
    "@babel/plugin-transform-optional-chaining",
    "@babel/plugin-transform-class-static-block"
  ]
}
