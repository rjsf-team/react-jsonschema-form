{
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.[jt]sx?$": [
      "@swc/jest",
      {
        "jsc": {
          "transform": {
            "react": {
              "runtime": "automatic"
            }
          },
          "target": "es2020"
        }
      }
    ]
  },
  "setupFilesAfterEnv": [
    "../../testing/testSetup.ts",
    "<rootDir>/test/setup-jest-env.ts"
  ],
  "transformIgnorePatterns": [
    "/node_modules/(?!(@x0k/json-schema-merge|deep-freeze-es6))"
  ],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "coverageProvider": "v8"
}
