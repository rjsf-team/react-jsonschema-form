{
  "setupFilesAfterEnv": [
    "../../testing/testSetup.ts"
  ],
  "snapshotSerializers": [
    "@emotion/jest/serializer"
  ],
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.[jt]sx?$": [
      "@swc/jest",
      {
        "jsc": {
          "transform": {
            "react": {
              "runtime": "automatic"
            }
          },
          "target": "es2020"
        }
      }
    ]
  },
  "testEnvironmentOptions": {
    "browsers": [
      "chrome",
      "firefox",
      "safari"
    ]
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(@x0k/json-schema-merge|deep-freeze-es6))"
  ],
  "coverageProvider": "v8"
}
