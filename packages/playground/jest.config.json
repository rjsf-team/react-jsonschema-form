{
  "verbose": true,
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.[jt]sx?$": [
      "@swc/jest",
      {
        "jsc": {
          "transform": {
            "react": {
              "runtime": "automatic"
            }
          },
          "target": "es2020"
        }
      }
    ]
  },
  "testMatch": [
    "**/test/**/*.test.[jt]s?(x)"
  ],
  "transformIgnorePatterns": [
    "/node_modules/(?!deep-freeze-es6)"
  ],
  "coverageProvider": "v8"
}
