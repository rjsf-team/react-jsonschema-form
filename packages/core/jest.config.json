{
  "verbose": true,
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.[jt]sx?$": [
      "@swc/jest",
      {
        "jsc": {
          "transform": {
            "react": {
              "runtime": "automatic"
            }
          },
          "target": "es2020"
        }
      }
    ]
  },
  "setupFilesAfterEnv": [
    "./test/setup-jest-env.ts",
    "../../testing/testSetup.ts"
  ],
  "testMatch": [
    "**/test/**/*.test.[jt]s?(x)"
  ],
  "transformIgnorePatterns": [
    "/node_modules/(?!(@x0k/json-schema-merge|deep-freeze-es6))"
  ],
  "coverageProvider": "v8"
}
